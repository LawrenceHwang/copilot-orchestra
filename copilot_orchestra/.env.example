# Copilot Orchestra — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Application ────────────────────────────────────────────────────────────
APP_NAME="Copilot Orchestra"
DEBUG=false
LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Copilot CLI ─────────────────────────────────────────────────────────────
# Leave empty to use the bundled CLI or $PATH
# COPILOT_CLI_PATH=/opt/homebrew/bin/copilot

# ─── Authentication ───────────────────────────────────────────────────────────
# Option 1: Use the logged-in Copilot account (default — works if `copilot auth status` is OK)
USE_LOGGED_IN_USER=true

# Option 2: Explicit GitHub token (disables logged-in user)
# GITHUB_TOKEN=ghp_...

# ─── BYOK — Bring Your Own Key ───────────────────────────────────────────────
# Set these to use a custom AI provider instead of GitHub Copilot
# BYOK_PROVIDER_TYPE=anthropic          # openai | anthropic | azure
# BYOK_API_KEY=sk-ant-...
# BYOK_BASE_URL=                        # leave empty to use provider default

# ─── Default Models ──────────────────────────────────────────────────────────
# These are the defaults for the "balanced" preset.
# Users can override per-role in the UI.
DEFAULT_ORCHESTRATOR_MODEL=claude-sonnet-4-6
DEFAULT_SECURITY_MODEL=claude-opus-4-6
DEFAULT_PERFORMANCE_MODEL=claude-sonnet-4-6
DEFAULT_READABILITY_MODEL=claude-haiku-4-5-20251001
DEFAULT_SYNTHESIZER_MODEL=claude-sonnet-4-6
